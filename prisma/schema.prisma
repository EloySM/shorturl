generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DeviceType {
  MOBILE
  DESKTOP
  UNKNOWN
}

model clicks {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  link_id      String?   @db.Uuid
  ip_hash      String?
  ip_display   String?
  continent    String?
  country_code String?
  country_region  String?
  city         String?
  device_type  DeviceType @default(UNKNOWN)
  os           String?
  browser      String?
  detected_source String?
  referrer     String?   @db.Text
  utm_source   String?
  utm_medium   String?
  utm_campaign String?
  is_unique    Boolean?  @default(true)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  links        links?    @relation(fields: [link_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([link_id])
  @@index([ip_hash])
}

model links {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  short_code        String         @unique
  original_url      String
  organization_id   String?        @db.Uuid
  creator_id        String?        @db.Uuid
  expires_at        DateTime?      @db.Timestamptz(6)
  og_title          String?
  og_description    String?
  og_image          String?
  pass_query_params Boolean?       @default(true)
  link_cloaking     Boolean?       @default(false)
  is_unsafe         Boolean?       @default(false)
  ios_url           String?
  android_url       String?
  created_at        DateTime?      @default(now()) @db.Timestamptz(6)
  clicks            clicks[]
  users             users?         @relation(fields: [creator_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations     organizations? @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model memberships {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organization_id String?        @db.Uuid
  user_id         String?        @db.Uuid
  role            user_role?     @default(VIEWER)
  organizations   organizations? @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users           users?         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([organization_id, user_id])
}

model organizations {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String        @unique
  created_at  DateTime?     @default(now()) @db.Timestamptz(6)
  links       links[]
  memberships memberships[]
}

model users {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String        @unique
  created_at  DateTime?     @default(now()) @db.Timestamptz(6)
  links       links[]
  memberships memberships[]
}

enum user_role {
  OWNER
  ADMIN
  VIEWER
}
